{
  "name": "dbq",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run build:release",
    "build:auth": "swiftc bin/confirm-query.swift -o dist/package/bin/dbq-confirm",
    "build:cli": "bun build --compile --outfile dist/package/bin/dbq src/index.ts",
    "build:release": "bash scripts/build-release.sh",
    "check": "bun run format && bun run lint && bun run typecheck",
    "format": "oxfmt --write .",
    "lint": "oxlint . --deny-warnings",
    "start": "bun run src/index.ts",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@effect/cli": "^0.75.2",
    "@effect/platform-bun": "^0.90.0",
    "effect": "^3.21.2",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/pg": "^8.20.0",
    "@typescript/native-preview": "^7.0.0-dev.20260604.1",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "oxlint-plugin-eslint": "^1.68.0"
  }
}
